export default async function handler(req, res) {

  const num = req.query.num;

  if (!num) {
    return res.status(400).json({ error: "Vehicle number required" });
  }

  const url = "https://vehicle-chalan-check-api-by-abhigyan.onrender.com/api/challan?vehicle_number=" + num;

  // 🔥 retry system
  async function fetchWithRetry(retries = 3) {
    for (let i = 0; i < retries; i++) {
      try {

        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 10000);

        const response = await fetch(url, {
          signal: controller.signal
        });

        clearTimeout(timeout);

        const text = await response.text();

        // safe JSON parse
        try {
          return JSON.parse(text);
        } catch {
          throw "Invalid JSON";
        }

      } catch (e) {
        if (i === retries - 1) throw e;
        await new Promise(r => setTimeout(r, 2000)); // wait
      }
    }
  }

  try {

    const data = await fetchWithRetry();

    return res.status(200).json(data);

  } catch (err) {
    return res.status(500).json({
      error: "API unreachable",
      message: "Server slow or blocked"
    });
  }
}
